# ===== SOCIAL PASS =====
def social_pass(base, data):
    nums = data.get("nums") or ["123"]

    base_variants = [
        base + data.get("year", ""),
        base + random.choice(nums),
        base + random.choice(COMMON_SUFFIX),
    ]

    results = []

    for p in base_variants:
        for s in SPECIAL:
          results.append(p + s)   

        # optional variation (rare)
        if random.random() > 0.85:
            results.append(p + random.choice(SPECIAL))

    if data.get("phone") and len(data["phone"]) >= 4:
        results.append(base + data["phone"][-4:])

    return random.choice(results)

# ===== WIFI PASS =====
def wifi_pass(base, data):
    nums = data.get("nums") or ["123"]
    results = []

    for n in nums:
        results.append(base + n)
        results.append(base + n + random.choice(SPECIAL))

    if data.get("ssid"):
        results.append(data["ssid"] + random.choice(nums))

    if data.get("isp"):
        results.append(data["isp"] + random.choice(COMMON_SUFFIX))

    if data.get("phone") and len(data["phone"]) >= 8:
        results.append(data["phone"][-8:])

    # strong wifi
    results.append(base + str(random.randint(10000000, 99999999)))

    return random.choice(results)

# ===== GENERATE =====
def generate(data, total, mode):
    words = set()

    base_words = [v for v in data.values() if isinstance(v, str) and len(v) > 1]

    if not base_words:
        print(" No data!")
        return []

    tries = 0
    max_tries = total * 20

    while len(words) < total and tries < max_tries:
        base = random.choice(base_words)

        if mode == "social":
            word = social_pass(base, data)
        else:
            word = wifi_pass(base, data)

        
        if random.random() > 0.5:
            word = word.capitalize()

        words.add(word)
        tries += 1

        if len(words) % 500 == 0:
            print(Fore.RED + f"\rGenerating {len(words)}/{total}", end="")
        word = word.replace("!!", "!").replace("@@", "@").replace("##", "#")

    print()
    return list(words)

# ===== SAVE =====
def save_file(words):
    name = input("Filename: ") or "pass.txt"
    with open(name, "w") as f:
        for w in words:
            f.write(w + "\n")
    print(Fore.GREEN + f"Saved {len(words)} passwords" + Style.RESET_ALL)

